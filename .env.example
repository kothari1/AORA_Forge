# Copy to .env (gitignored) or export directly.
#
# AORA-Forge speaks to three LLM providers through one interface. The active
# provider is chosen by AORA_FORGE_PROVIDER if set, else the first reachable
# credential below (Anthropic -> OpenAI -> Vertex), else a deterministic mock.

# --- provider selection (optional) -----------------------------------------
# one of: anthropic | openai | vertex | mock   (gemini/claude aliases accepted)
# AORA_FORGE_PROVIDER=vertex

# --- Anthropic (Claude API) ------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-your-key-here
#   defaults: planner=claude-opus-4-8, worker=claude-haiku-4-5

# --- OpenAI ----------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key
#   defaults: planner=gpt-4o, worker=gpt-4o-mini

# --- Google Gemini via Vertex AI (service-account) -------------------------
# Place the service-account JSON at .secrets/gcp-lead-sa.json (gitignored) — the
# default — or point at it explicitly:
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/sa.json
# AORA_FORGE_GCP_PROJECT=gcp-lead       # else read from the SA file's project_id
# AORA_FORGE_GCP_LOCATION=us-central1   # default
#   defaults: planner=gemini-2.5-pro, worker=gemini-2.5-flash

# --- per-provider model overrides (optional) -------------------------------
# AORA_FORGE_VERTEX_PLANNER_MODEL=gemini-2.5-pro
# AORA_FORGE_OPENAI_WORKER_MODEL=gpt-4o-mini

# --- retrieval embeddings (optional) ---------------------------------------
# Use sentence-transformers instead of the offline hashing embedder
# (downloads all-MiniLM-L6-v2 on first use).
# AORA_FORGE_USE_ST=1
