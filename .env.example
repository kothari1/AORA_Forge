# Copy to .env (gitignored) or export directly.
#
# AORA-Forge's LLM calls go through the Anthropic SDK only. With this key set,
# scripts/demo_full_loop.py and the pipelines hit the real Claude API
# (Opus 4.8 for planning/spec-gen, Haiku 4.5 for validation). Without it, the
# deterministic MockLLMClient runs the whole pipeline offline.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: use sentence-transformers for retrieval embeddings instead of the
# default offline hashing embedder (downloads all-MiniLM-L6-v2 on first use).
# AORA_FORGE_USE_ST=1
